digraph DraxulArchitecture {
  graph [
    label="Draxul Architecture",
    labelloc=t,
    fontsize=26,
    fontname="Helvetica",
    rankdir=TB,
    ordering=out,
    splines=polyline,
    overlap=false,
    pad=0.3,
    nodesep=0.22,
    ranksep=0.8,
    bgcolor="white"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=11,
    margin="0.12,0.08",
    color="#355070",
    penwidth=1.2
  ];

  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#4a5568",
    penwidth=1.1,
    arrowsize=0.8
  ];

  // Color system:
  // interfaces: blue (#dcecff / #4f83cc)
  // abstract bases: yellow (#ffe9a8 / #c7981d)
  // concrete classes: green (#d9f5dd / #3d8c50)
  // app orchestrators: red (#ffd7d7 / #b53a3a)
  // support/pipeline: purple (#eadbff / #7a4cc2)

  // ─────────────────────────────────────────────────
  // App layer
  // ─────────────────────────────────────────────────

  subgraph cluster_app {
    label="App layer";
    color="#c94f4f";
    style="rounded";

    App [label=<
      <b>App</b><br/>
      top-level runtime coordinator
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    HostManager [label=<
      <b>HostManager</b><br/>
      owns pane hosts + lifecycle
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    SplitTree [label=<
      <b>SplitTree</b><br/>
      pane layout + divider hit-testing
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    InputDispatcher [label=<
      <b>InputDispatcher</b><br/>
      routes window input
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    GuiActionHandler [label=<
      <b>GuiActionHandler</b><br/>
      named app actions
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    UiPanel [label=<
      <b>UiPanel</b><br/>
      diagnostics UI
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    DiagnosticsCollector [label=<
      <b>DiagnosticsCollector</b><br/>
      startup timing
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    FrameTimer [label=<
      <b>FrameTimer</b><br/>
      frame timing stats
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    MacOsMenu [label=<
      <b>MacOsMenu</b><br/>
      native menu integration
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    App -> HostManager [style=invis, weight=30];
    HostManager -> SplitTree [style=invis, weight=30];
    SplitTree -> InputDispatcher [style=invis, weight=30];
    InputDispatcher -> GuiActionHandler [style=invis, weight=30];
    GuiActionHandler -> UiPanel [style=invis, weight=30];
    UiPanel -> DiagnosticsCollector [style=invis, weight=30];
    DiagnosticsCollector -> FrameTimer [style=invis, weight=30];
    FrameTimer -> MacOsMenu [style=invis, weight=30];
  }

  // ─────────────────────────────────────────────────
  // Renderer hierarchy
  // ─────────────────────────────────────────────────

  subgraph cluster_renderer {
    label="Renderer hierarchy";
    color="#4f83cc";
    style="rounded";

    IBaseRenderer [label=<
      <b>IBaseRenderer</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    I3DRenderer [label=<
      <b>I3DRenderer</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    IGridRenderer [label=<
      <b>IGridRenderer</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    IRenderPass [label=<
      <b>IRenderPass</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    IRenderContext [label=<
      <b>IRenderContext</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    IImGuiHost [label=<
      <b>IImGuiHost</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    ICaptureRenderer [label=<
      <b>ICaptureRenderer</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    RendererBundle [label=<
      <b>RendererBundle</b><br/>
      typed access to renderer capabilities
    >, fillcolor="#eadbff", color="#7a4cc2"];

    IGridHandle [label=<
      <b>IGridHandle</b><br/>
      per-host GPU grid state
    >, fillcolor="#dcecff", color="#4f83cc"];

    MetalRenderer [label=<
      <b>MetalRenderer</b><br/>
      macOS backend
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    MetalRenderContext [label=<
      <b>MetalRenderContext</b>
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    VkRenderer [label=<
      <b>VkRenderer</b><br/>
      Windows backend
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    VkRenderContext [label=<
      <b>VkRenderContext</b>
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    IBaseRenderer -> I3DRenderer [style=invis, weight=30];
    I3DRenderer -> IGridRenderer [style=invis, weight=30];
    IGridRenderer -> IRenderPass [style=invis, weight=30];
    IRenderPass -> IRenderContext [style=invis, weight=30];
    IRenderContext -> IImGuiHost [style=invis, weight=30];
    IImGuiHost -> ICaptureRenderer [style=invis, weight=30];
    ICaptureRenderer -> RendererBundle [style=invis, weight=30];
    RendererBundle -> IGridHandle [style=invis, weight=30];
    IGridHandle -> MetalRenderer [style=invis, weight=30];
    MetalRenderer -> MetalRenderContext [style=invis, weight=30];
    MetalRenderContext -> VkRenderer [style=invis, weight=30];
    VkRenderer -> VkRenderContext [style=invis, weight=30];
  }

  // ─────────────────────────────────────────────────
  // Host hierarchy
  // ─────────────────────────────────────────────────

  subgraph cluster_hosts {
    label="Host hierarchy";
    color="#d6b04f";
    style="rounded";

    IHostCallbacks [label=<
      <b>IHostCallbacks</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    IHost [label=<
      <b>IHost</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    I3DHost [label=<
      <b>I3DHost</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    IGridHost [label=<
      <b>IGridHost</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    GridHostBase [label=<
      <b>GridHostBase</b><br/>
      common grid-host runtime
    >, fillcolor="#ffe9a8", color="#c7981d"];

    TerminalHostBase [label=<
      <b>TerminalHostBase</b><br/>
      VT terminal core
    >, fillcolor="#ffe9a8", color="#c7981d"];

    LocalTerminalHost [label=<
      <b>LocalTerminalHost</b><br/>
      bash / zsh / powershell / WSL<br/>
      selection + scrollback + mouse
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    NvimHost [label=<
      <b>NvimHost</b>
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    MegaCityHost [label=<
      <b>MegaCityHost</b><br/>
      code-analysis 3D city
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    IHostCallbacks -> IHost [style=invis, weight=30];
    IHost -> I3DHost [style=invis, weight=30];
    I3DHost -> IGridHost [style=invis, weight=30];
    IGridHost -> GridHostBase [style=invis, weight=30];
    GridHostBase -> TerminalHostBase [style=invis, weight=30];
    TerminalHostBase -> LocalTerminalHost [style=invis, weight=30];
    LocalTerminalHost -> NvimHost [style=invis, weight=30];
    NvimHost -> MegaCityHost [style=invis, weight=30];
  }

  // ─────────────────────────────────────────────────
  // Window
  // ─────────────────────────────────────────────────

  subgraph cluster_window {
    label="Window";
    color="#4f83cc";
    style="rounded";

    IWindow [label=<
      <b>IWindow</b>
    >, fillcolor="#dcecff", color="#4f83cc"];

    SdlWindow [label=<
      <b>SdlWindow</b><br/>
      SDL3 implementation
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    IWindow -> SdlWindow [style=invis, weight=30];
  }

  // ─────────────────────────────────────────────────
  // Font & Grid
  // ─────────────────────────────────────────────────

  subgraph cluster_grid {
    label="Font & Grid";
    color="#7a4cc2";
    style="rounded";

    TextService [label=<
      <b>TextService</b><br/>
      fonts, shaping, atlas
    >, fillcolor="#eadbff", color="#7a4cc2"];

    Grid [label=<
      <b>Grid</b><br/>
      cell model + dirty tracking
    >, fillcolor="#eadbff", color="#7a4cc2"];

    HighlightTable [label=<
      <b>HighlightTable</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    GridRenderingPipeline [label=<
      <b>GridRenderingPipeline</b><br/>
      grid to draw updates
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CursorBlinker [label=<
      <b>CursorBlinker</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    VtParser [label=<
      <b>VtParser</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    VtState [label=<
      <b>VtState</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    AltScreenManager [label=<
      <b>AltScreenManager</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    MouseReporter [label=<
      <b>MouseReporter</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    SelectionManager [label=<
      <b>SelectionManager</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    ScrollbackBuffer [label=<
      <b>ScrollbackBuffer</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    TextService -> Grid [style=invis, weight=30];
    Grid -> HighlightTable [style=invis, weight=30];
    HighlightTable -> GridRenderingPipeline [style=invis, weight=30];
    GridRenderingPipeline -> CursorBlinker [style=invis, weight=30];
    CursorBlinker -> VtParser [style=invis, weight=30];
    VtParser -> VtState [style=invis, weight=30];
    VtState -> AltScreenManager [style=invis, weight=30];
    AltScreenManager -> MouseReporter [style=invis, weight=30];
    MouseReporter -> SelectionManager [style=invis, weight=30];
    SelectionManager -> ScrollbackBuffer [style=invis, weight=30];
  }

  // ─────────────────────────────────────────────────
  // Neovim runtime
  // ─────────────────────────────────────────────────

  subgraph cluster_nvim {
    label="Neovim runtime";
    color="#7a4cc2";
    style="rounded";

    NvimProcess [label=<
      <b>NvimProcess</b><br/>
      child process wrapper
    >, fillcolor="#eadbff", color="#7a4cc2"];

    NvimRpc [label=<
      <b>NvimRpc</b><br/>
      msgpack-RPC transport
    >, fillcolor="#eadbff", color="#7a4cc2"];

    UiEventHandler [label=<
      <b>UiEventHandler</b><br/>
      redraw decoder
    >, fillcolor="#eadbff", color="#7a4cc2"];

    NvimInput [label=<
      <b>NvimInput</b><br/>
      input encoder
    >, fillcolor="#eadbff", color="#7a4cc2"];

    UiRequestWorker [label=<
      <b>UiRequestWorker</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    StartupResizeState [label=<
      <b>StartupResizeState</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    NvimProcess -> NvimRpc [style=invis, weight=30];
    NvimRpc -> UiEventHandler [style=invis, weight=30];
    UiEventHandler -> NvimInput [style=invis, weight=30];
    NvimInput -> UiRequestWorker [style=invis, weight=30];
    UiRequestWorker -> StartupResizeState [style=invis, weight=30];
  }

  // ─────────────────────────────────────────────────
  // MegaCity subsystem
  // ─────────────────────────────────────────────────

  subgraph cluster_megacity {
    label="MegaCity subsystem";
    color="#2d6a4f";
    style="rounded";

    SceneWorld [label=<
      <b>SceneWorld</b><br/>
      ECS registry (EnTT)
    >, fillcolor="#eadbff", color="#7a4cc2"];

    IsometricCamera [label=<
      <b>IsometricCamera</b><br/>
      ortho projection + orbit
    >, fillcolor="#eadbff", color="#7a4cc2"];

    IsometricScenePass [label=<
      <b>IsometricScenePass</b><br/>
      implements IRenderPass
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    CubeRenderPass [label=<
      <b>CubeRenderPass</b><br/>
      implements IRenderPass
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    MeshLibrary [label=<
      <b>MeshLibrary</b><br/>
      cube, floor, sign meshes
    >, fillcolor="#eadbff", color="#7a4cc2"];

    SemanticCityLayout [label=<
      <b>SemanticCityLayout</b><br/>
      code-analysis city generation<br/>
      spiral layout per module
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CityGrid [label=<
      <b>CityGrid</b><br/>
      2D occupancy grid<br/>
      building/road/park cells
    >, fillcolor="#eadbff", color="#7a4cc2"];

    SignLabelAtlas [label=<
      <b>SignLabelAtlas</b><br/>
      building + module name labels
    >, fillcolor="#eadbff", color="#7a4cc2"];

    MegaCityCodeConfig [label=<
      <b>MegaCityCodeConfig</b><br/>
      visualization tuning params
    >, fillcolor="#eadbff", color="#7a4cc2"];

    TreesitterPanel [label=<
      <b>TreesitterPanel</b><br/>
      ImGui codebase analysis UI
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CityMapPanel [label=<
      <b>CityMapPanel</b><br/>
      ImGui 2D grid overview
    >, fillcolor="#eadbff", color="#7a4cc2"];

    SceneWorld -> IsometricCamera [style=invis, weight=30];
    IsometricCamera -> IsometricScenePass [style=invis, weight=30];
    IsometricScenePass -> CubeRenderPass [style=invis, weight=30];
    CubeRenderPass -> MeshLibrary [style=invis, weight=30];
    MeshLibrary -> SemanticCityLayout [style=invis, weight=30];
    SemanticCityLayout -> CityGrid [style=invis, weight=30];
    CityGrid -> SignLabelAtlas [style=invis, weight=30];
    SignLabelAtlas -> MegaCityCodeConfig [style=invis, weight=30];
    MegaCityCodeConfig -> TreesitterPanel [style=invis, weight=30];
    TreesitterPanel -> CityMapPanel [style=invis, weight=30];
  }

  // ─────────────────────────────────────────────────
  // Code analysis pipeline
  // ─────────────────────────────────────────────────

  subgraph cluster_codeanalysis {
    label="Code analysis pipeline";
    color="#7a4cc2";
    style="rounded";

    CodebaseScanner [label=<
      <b>CodebaseScanner</b><br/>
      background tree-sitter scan
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CodebaseSnapshot [label=<
      <b>CodebaseSnapshot</b><br/>
      immutable parse result
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CityDatabase [label=<
      <b>CityDatabase</b><br/>
      SQLite symbol storage
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CityClassRecord [label=<
      <b>CityClassRecord</b><br/>
      mapped entity data
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CityModuleRecord [label=<
      <b>CityModuleRecord</b><br/>
      per-module quality metric
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CodebaseScanner -> CodebaseSnapshot [style=invis, weight=30];
    CodebaseSnapshot -> CityDatabase [style=invis, weight=30];
    CityDatabase -> CityClassRecord [style=invis, weight=30];
    CityClassRecord -> CityModuleRecord [style=invis, weight=30];
  }

  // ─────────────────────────────────────────────────
  // ECS components (data-only)
  // ─────────────────────────────────────────────────

  subgraph cluster_ecs {
    label="ECS components";
    color="#2d6a4f";
    style="rounded";

    WorldPosition [label=<
      <b>WorldPosition</b><br/>
      x, z ground plane
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    Elevation [label=<
      <b>Elevation</b>
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    Appearance [label=<
      <b>Appearance</b><br/>
      mesh ID + color
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    BuildingMetrics [label=<
      <b>BuildingMetrics</b><br/>
      footprint, height, road
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    RoadMetrics [label=<
      <b>RoadMetrics</b>
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    RoadSurfaceMetrics [label=<
      <b>RoadSurfaceMetrics</b>
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    TreeMetrics [label=<
      <b>TreeMetrics</b>
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    SignMetrics [label=<
      <b>SignMetrics</b>
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    SourceSymbol [label=<
      <b>SourceSymbol</b><br/>
      file + name link
    >, fillcolor="#d9f5dd", color="#3d8c50"];

    WorldPosition -> Elevation [style=invis, weight=30];
    Elevation -> Appearance [style=invis, weight=30];
    Appearance -> BuildingMetrics [style=invis, weight=30];
    BuildingMetrics -> RoadMetrics [style=invis, weight=30];
    RoadMetrics -> RoadSurfaceMetrics [style=invis, weight=30];
    RoadSurfaceMetrics -> TreeMetrics [style=invis, weight=30];
    TreeMetrics -> SignMetrics [style=invis, weight=30];
    SignMetrics -> SourceSymbol [style=invis, weight=30];
  }

  // ═════════════════════════════════════════════════
  // Inheritance: hollow arrows
  // ═════════════════════════════════════════════════

  // Renderer hierarchy
  SdlWindow -> IWindow [arrowhead=empty, label="implements"];
  I3DRenderer -> IBaseRenderer [arrowhead=empty, label="extends"];
  IGridRenderer -> I3DRenderer [arrowhead=empty, label="extends"];
  MetalRenderer -> IGridRenderer [arrowhead=empty, label="implements"];
  MetalRenderer -> IImGuiHost [arrowhead=empty, label="implements"];
  MetalRenderer -> ICaptureRenderer [arrowhead=empty, label="implements"];
  VkRenderer -> IGridRenderer [arrowhead=empty, label="implements"];
  VkRenderer -> IImGuiHost [arrowhead=empty, label="implements"];
  VkRenderer -> ICaptureRenderer [arrowhead=empty, label="implements"];
  MetalRenderContext -> IRenderContext [arrowhead=empty, label="implements"];
  VkRenderContext -> IRenderContext [arrowhead=empty, label="implements"];
  IsometricScenePass -> IRenderPass [arrowhead=empty, label="implements"];
  CubeRenderPass -> IRenderPass [arrowhead=empty, label="implements"];

  // Host hierarchy
  I3DHost -> IHost [arrowhead=empty, label="extends"];
  IGridHost -> I3DHost [arrowhead=empty, label="extends"];
  GridHostBase -> IGridHost [arrowhead=empty, label="extends"];
  TerminalHostBase -> GridHostBase [arrowhead=empty, label="extends"];
  LocalTerminalHost -> TerminalHostBase [arrowhead=empty, label="extends"];
  NvimHost -> GridHostBase [arrowhead=empty, label="extends"];
  MegaCityHost -> I3DHost [arrowhead=empty, label="implements"];
  App -> IHostCallbacks [arrowhead=empty, label="implements"];

  // ═════════════════════════════════════════════════
  // Composition/ownership: dashed line, filled arrow
  // ═════════════════════════════════════════════════

  // App owns
  App -> HostManager [style=dashed, arrowhead=vee, label="owns"];
  App -> InputDispatcher [style=dashed, arrowhead=vee, label="owns"];
  App -> GuiActionHandler [style=dashed, arrowhead=vee, label="owns"];
  App -> UiPanel [style=dashed, arrowhead=vee, label="owns"];
  App -> DiagnosticsCollector [style=dashed, arrowhead=vee, label="owns"];
  App -> FrameTimer [style=dashed, arrowhead=vee, label="owns"];
  App -> IWindow [style=dashed, arrowhead=vee, label="owns"];
  App -> RendererBundle [style=dashed, arrowhead=vee, label="owns"];
  App -> TextService [style=dashed, arrowhead=vee, label="owns"];

  // HostManager owns
  HostManager -> SplitTree [style=dashed, arrowhead=vee, label="owns"];
  HostManager -> IHost [style=dashed, arrowhead=vee, label="owns hosts"];

  // GridHostBase owns
  GridHostBase -> Grid [style=dashed, arrowhead=vee, label="owns"];
  GridHostBase -> HighlightTable [style=dashed, arrowhead=vee, label="owns"];
  GridHostBase -> GridRenderingPipeline [style=dashed, arrowhead=vee, label="owns"];
  GridHostBase -> CursorBlinker [style=dashed, arrowhead=vee, label="owns"];
  GridHostBase -> IGridHandle [style=dashed, arrowhead=vee, label="owns"];

  // TerminalHostBase owns
  TerminalHostBase -> VtParser [style=dashed, arrowhead=vee, label="owns"];
  TerminalHostBase -> VtState [style=dashed, arrowhead=vee, label="owns"];
  TerminalHostBase -> AltScreenManager [style=dashed, arrowhead=vee, label="owns"];

  // LocalTerminalHost owns
  LocalTerminalHost -> MouseReporter [style=dashed, arrowhead=vee, label="owns"];
  LocalTerminalHost -> SelectionManager [style=dashed, arrowhead=vee, label="owns"];
  LocalTerminalHost -> ScrollbackBuffer [style=dashed, arrowhead=vee, label="owns"];

  // NvimHost owns
  NvimHost -> NvimProcess [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> NvimRpc [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> UiEventHandler [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> NvimInput [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> UiRequestWorker [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> StartupResizeState [style=dashed, arrowhead=vee, label="owns"];

  // MegaCityHost owns
  MegaCityHost -> SceneWorld [style=dashed, arrowhead=vee, label="owns"];
  MegaCityHost -> IsometricCamera [style=dashed, arrowhead=vee, label="owns"];
  MegaCityHost -> IsometricScenePass [style=dashed, arrowhead=vee, label="owns (shared)"];
  MegaCityHost -> CubeRenderPass [style=dashed, arrowhead=vee, label="owns (shared)"];
  MegaCityHost -> CodebaseScanner [style=dashed, arrowhead=vee, label="owns"];
  MegaCityHost -> CityDatabase [style=dashed, arrowhead=vee, label="owns"];
  MegaCityHost -> SignLabelAtlas [style=dashed, arrowhead=vee, label="owns (shared)"];
  MegaCityHost -> MegaCityCodeConfig [style=dashed, arrowhead=vee, label="owns"];
  MegaCityHost -> CityGrid [style=dashed, arrowhead=vee, label="builds (bg thread)"];

  // SceneWorld owns ECS components
  SceneWorld -> WorldPosition [style=dashed, arrowhead=vee, label="registry stores"];
  SceneWorld -> Appearance [style=dashed, arrowhead=vee, label="registry stores"];
  SceneWorld -> BuildingMetrics [style=dashed, arrowhead=vee, label="registry stores"];

  // ═════════════════════════════════════════════════
  // Cross-links (uses / queries)
  // ═════════════════════════════════════════════════

  RendererBundle -> IGridRenderer [label="grid()", constraint=false, color="#94a3b8"];
  RendererBundle -> IImGuiHost [label="imgui()", constraint=false, color="#94a3b8"];
  RendererBundle -> ICaptureRenderer [label="capture()", constraint=false, color="#94a3b8"];
  RendererBundle -> I3DRenderer [label="threed()", constraint=false, color="#94a3b8"];

  GridRenderingPipeline -> TextService [label="shapes via", constraint=false, color="#94a3b8"];
  GridRenderingPipeline -> Grid [label="reads cells", constraint=false, color="#94a3b8"];
  GridRenderingPipeline -> IGridHandle [label="flushes to", constraint=false, color="#94a3b8"];

  GridHostBase -> IWindow [label="uses", constraint=false, color="#94a3b8"];
  GridHostBase -> IGridRenderer [label="uses", constraint=false, color="#94a3b8"];
  GridHostBase -> TextService [label="uses", constraint=false, color="#94a3b8"];
  GridHostBase -> IHostCallbacks [label="notifies", constraint=false, color="#94a3b8"];

  HostManager -> IWindow [label="supplies host context", constraint=false, color="#94a3b8"];
  HostManager -> IGridRenderer [label="supplies host context", constraint=false, color="#94a3b8"];
  HostManager -> TextService [label="supplies host context", constraint=false, color="#94a3b8"];
  HostManager -> IHostCallbacks [label="passes observer", constraint=false, color="#94a3b8"];

  InputDispatcher -> IWindow [label="connects callbacks", constraint=false, color="#94a3b8"];
  InputDispatcher -> HostManager [label="mouse hit-test", constraint=false, color="#94a3b8"];
  InputDispatcher -> IHost [label="forwards input", constraint=false, color="#94a3b8"];
  InputDispatcher -> UiPanel [label="routes panel input", constraint=false, color="#94a3b8"];

  GuiActionHandler -> TextService [label="font actions", constraint=false, color="#94a3b8"];
  GuiActionHandler -> UiPanel [label="toggle diagnostics", constraint=false, color="#94a3b8"];
  GuiActionHandler -> IHost [label="copy/paste/actions", constraint=false, color="#94a3b8"];
  GuiActionHandler -> HostManager [label="split panes", constraint=false, color="#94a3b8"];
  GuiActionHandler -> IImGuiHost [label="font texture rebuild", constraint=false, color="#94a3b8"];

  UiPanel -> IImGuiHost [label="produces ImGui draw data", constraint=false, color="#94a3b8"];
  App -> IGridRenderer [label="frame lifecycle", constraint=false, color="#94a3b8"];

  NvimRpc -> NvimProcess [label="transport over", constraint=false, color="#94a3b8"];
  UiEventHandler -> Grid [label="writes redraws", constraint=false, color="#94a3b8"];
  UiEventHandler -> HighlightTable [label="updates attrs", constraint=false, color="#94a3b8"];
  NvimInput -> NvimRpc [label="sends input", constraint=false, color="#94a3b8"];
  UiRequestWorker -> NvimRpc [label="async requests", constraint=false, color="#94a3b8"];

  // MegaCity cross-links
  MegaCityHost -> I3DRenderer [label="registers 3D pass", constraint=false, color="#94a3b8"];
  MegaCityHost -> IImGuiHost [label="contributes ImGui", constraint=false, color="#94a3b8"];
  MegaCityHost -> TextService [label="sign label rendering", constraint=false, color="#94a3b8"];
  IsometricScenePass -> IRenderContext [label="records into", constraint=false, color="#94a3b8"];
  SemanticCityLayout -> CityClassRecord [label="reads from", constraint=false, color="#94a3b8"];
  SemanticCityLayout -> MegaCityCodeConfig [label="tuned by", constraint=false, color="#94a3b8"];
  SemanticCityLayout -> CityGrid [label="produces", constraint=false, color="#94a3b8"];
  CityGrid -> CityMapPanel [label="rendered by", constraint=false, color="#94a3b8"];
  CodebaseScanner -> CodebaseSnapshot [label="produces", constraint=false, color="#94a3b8"];
  CityDatabase -> CodebaseSnapshot [label="reconciles", constraint=false, color="#94a3b8"];
  CityDatabase -> CityClassRecord [label="queries", constraint=false, color="#94a3b8"];
  CityDatabase -> CityModuleRecord [label="queries", constraint=false, color="#94a3b8"];
  SignLabelAtlas -> TextService [label="rasterizes via", constraint=false, color="#94a3b8"];
  TreesitterPanel -> CodebaseSnapshot [label="displays", constraint=false, color="#94a3b8"];

  // ═════════════════════════════════════════════════
  // Data flow
  // ═════════════════════════════════════════════════

  {
    rank=same;
    FlowStart [label=<
      <b>Data flow</b>
    >, fillcolor="#fff6d6", color="#c7981d"];

    WindowEvent [label=<
      <b>Window event</b>
    >, fillcolor="#fff6d6", color="#c7981d"];

    NvimPath [label=<
      <b>nvim path</b><br/>
      InputDispatcher -&gt; NvimHost -&gt; NvimInput -&gt; NvimRpc -&gt; nvim<br align="left"/>
      nvim redraw -&gt; NvimRpc -&gt; UiEventHandler -&gt; Grid -&gt; GridRenderingPipeline -&gt; Renderer
    >, fillcolor="#fff6d6", color="#c7981d"];

    TerminalPath [label=<
      <b>terminal path</b><br/>
      InputDispatcher -&gt; LocalTerminalHost -&gt; PTY/ConPTY write<br align="left"/>
      PTY output -&gt; VtParser/TerminalHostBase -&gt; Grid -&gt; GridRenderingPipeline -&gt; Renderer
    >, fillcolor="#fff6d6", color="#c7981d"];

    MegaCityPath [label=<
      <b>megacity path</b><br/>
      CodebaseScanner -&gt; CodebaseSnapshot -&gt; CityDatabase -&gt; CityClassRecord<br align="left"/>
      SemanticCityLayout -&gt; SceneWorld (ECS) -&gt; SceneSnapshot -&gt; IsometricScenePass -&gt; Renderer<br align="left"/>
      SemanticCityLayout -&gt; CityGrid (bg thread) -&gt; CityMapPanel (ImGui)
    >, fillcolor="#fff6d6", color="#c7981d"];
  }

  FlowStart -> WindowEvent [style=dashed, arrowhead=vee];
  WindowEvent -> NvimPath [style=dashed, arrowhead=vee];
  WindowEvent -> TerminalPath [style=dashed, arrowhead=vee];
  WindowEvent -> MegaCityPath [style=dashed, arrowhead=vee];

  // Threading note.
  Threading [label=<
    <b>Threading model</b><br align="left"/>
    Main thread: App loop, window events, rendering, host pump<br align="left"/>
    Nvim path: NvimRpc owns a reader thread for msgpack-RPC notifications<br align="left"/>
    MegaCity: CodebaseScanner runs a background tree-sitter scan thread<br align="left"/>
    MegaCity: CityGrid built on a background thread after layout completes<br align="left"/>
    Host wakeups: background I/O requests frame via IHostCallbacks::wake_window()<br align="left"/>
    Terminal local process I/O is drained/coalesced by host pump before rendering
  >, fillcolor="#fff6d6", color="#c7981d"];

  App -> Threading [style=dotted, arrowhead=none];
}
