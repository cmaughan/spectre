digraph DraxulConcreteOnly {
  graph [
    label="Draxul Concrete Runtime Classes",
    labelloc=t,
    fontsize=24,
    fontname="Helvetica",
    rankdir=TB,
    ordering=out,
    splines=polyline,
    overlap=false,
    pad=0.3,
    nodesep=0.28,
    ranksep=0.7,
    bgcolor="white"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=11,
    margin="0.12,0.08",
    color="#2f6b3b",
    fillcolor="#e8f7eb",
    penwidth=1.2
  ];

  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#496057",
    penwidth=1.1,
    arrowsize=0.8
  ];

  subgraph cluster_app {
    label="App runtime";
    color="#b53a3a";
    style="rounded";

    App [label=<
      <b>App</b><br/>
      top-level coordinator
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    HostManager [label=<
      <b>HostManager</b><br/>
      pane hosts + lifecycle
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    SplitTree [label=<
      <b>SplitTree</b>
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    InputDispatcher [label=<
      <b>InputDispatcher</b>
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    GuiActionHandler [label=<
      <b>GuiActionHandler</b>
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    UiPanel [label=<
      <b>UiPanel</b>
    >, fillcolor="#ffd7d7", color="#b53a3a"];

    FrameTimer [label=<
      <b>FrameTimer</b>
    >, fillcolor="#ffd7d7", color="#b53a3a"];
  }

  subgraph cluster_platform {
    label="Platform";
    color="#3d8c50";
    style="rounded";

    SdlWindow [label=<
      <b>SdlWindow</b><br/>
      SDL3 window implementation
    >];

    MetalRenderer [label=<
      <b>MetalRenderer</b><br/>
      macOS renderer
    >];

    VkRenderer [label=<
      <b>VkRenderer</b><br/>
      Windows renderer
    >];
  }

  subgraph cluster_text {
    label="Text + grid support";
    color="#7a4cc2";
    style="rounded";

    TextService [label=<
      <b>TextService</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    Grid [label=<
      <b>Grid</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    HighlightTable [label=<
      <b>HighlightTable</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    GridRenderingPipeline [label=<
      <b>GridRenderingPipeline</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    CursorBlinker [label=<
      <b>CursorBlinker</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    VtParser [label=<
      <b>VtParser</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    VtState [label=<
      <b>VtState</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    AltScreenManager [label=<
      <b>AltScreenManager</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    MouseReporter [label=<
      <b>MouseReporter</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    SelectionManager [label=<
      <b>SelectionManager</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    ScrollbackBuffer [label=<
      <b>ScrollbackBuffer</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];
  }

  subgraph cluster_nvim {
    label="Neovim concrete runtime";
    color="#7a4cc2";
    style="rounded";

    NvimProcess [label=<
      <b>NvimProcess</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    NvimRpc [label=<
      <b>NvimRpc</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    UiEventHandler [label=<
      <b>UiEventHandler</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    NvimInput [label=<
      <b>NvimInput</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    UiRequestWorker [label=<
      <b>UiRequestWorker</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];

    StartupResizeState [label=<
      <b>StartupResizeState</b>
    >, fillcolor="#eadbff", color="#7a4cc2"];
  }

  subgraph cluster_hosts {
    label="Concrete hosts";
    color="#3d8c50";
    style="rounded";

    NvimHost [label=<
      <b>NvimHost</b>
    >];

    ShellHost [label=<
      <b>ShellHost</b><br/>
      bash / zsh / WSL
    >];

    PowerShellHost [label=<
      <b>PowerShellHost</b>
    >];

    MegaCityHost [label=<
      <b>MegaCityHost</b>
    >];
  }

  // Ownership tree.
  App -> HostManager [style=dashed, arrowhead=vee, label="owns"];
  App -> InputDispatcher [style=dashed, arrowhead=vee, label="owns"];
  App -> GuiActionHandler [style=dashed, arrowhead=vee, label="owns"];
  App -> UiPanel [style=dashed, arrowhead=vee, label="owns"];
  App -> FrameTimer [style=dashed, arrowhead=vee, label="owns"];
  App -> SdlWindow [style=dashed, arrowhead=vee, label="owns window"];
  App -> TextService [style=dashed, arrowhead=vee, label="owns"];
  App -> MetalRenderer [style=dashed, arrowhead=vee, label="owns on macOS"];
  App -> VkRenderer [style=dashed, arrowhead=vee, label="owns on Windows"];

  HostManager -> SplitTree [style=dashed, arrowhead=vee, label="owns"];
  HostManager -> NvimHost [style=dashed, arrowhead=vee, label="creates/owns"];
  HostManager -> ShellHost [style=dashed, arrowhead=vee, label="creates/owns"];
  HostManager -> PowerShellHost [style=dashed, arrowhead=vee, label="creates/owns"];
  HostManager -> MegaCityHost [style=dashed, arrowhead=vee, label="creates/owns"];

  NvimHost -> Grid [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> HighlightTable [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> GridRenderingPipeline [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> CursorBlinker [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> NvimProcess [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> NvimRpc [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> UiEventHandler [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> NvimInput [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> UiRequestWorker [style=dashed, arrowhead=vee, label="owns"];
  NvimHost -> StartupResizeState [style=dashed, arrowhead=vee, label="owns"];

  ShellHost -> Grid [style=dashed, arrowhead=vee, label="owns grid state"];
  ShellHost -> HighlightTable [style=dashed, arrowhead=vee, label="owns"];
  ShellHost -> GridRenderingPipeline [style=dashed, arrowhead=vee, label="owns"];
  ShellHost -> CursorBlinker [style=dashed, arrowhead=vee, label="owns"];
  ShellHost -> VtParser [style=dashed, arrowhead=vee, label="owns"];
  ShellHost -> VtState [style=dashed, arrowhead=vee, label="owns"];
  ShellHost -> AltScreenManager [style=dashed, arrowhead=vee, label="owns"];
  ShellHost -> MouseReporter [style=dashed, arrowhead=vee, label="owns"];
  ShellHost -> SelectionManager [style=dashed, arrowhead=vee, label="owns"];
  ShellHost -> ScrollbackBuffer [style=dashed, arrowhead=vee, label="owns"];

  PowerShellHost -> Grid [style=dashed, arrowhead=vee, label="owns grid state"];
  PowerShellHost -> HighlightTable [style=dashed, arrowhead=vee, label="owns"];
  PowerShellHost -> GridRenderingPipeline [style=dashed, arrowhead=vee, label="owns"];
  PowerShellHost -> CursorBlinker [style=dashed, arrowhead=vee, label="owns"];
  PowerShellHost -> VtParser [style=dashed, arrowhead=vee, label="owns"];
  PowerShellHost -> VtState [style=dashed, arrowhead=vee, label="owns"];
  PowerShellHost -> AltScreenManager [style=dashed, arrowhead=vee, label="owns"];
  PowerShellHost -> MouseReporter [style=dashed, arrowhead=vee, label="owns"];
  PowerShellHost -> SelectionManager [style=dashed, arrowhead=vee, label="owns"];
  PowerShellHost -> ScrollbackBuffer [style=dashed, arrowhead=vee, label="owns"];

  // Non-owning/use links.
  GridRenderingPipeline -> TextService [constraint=false, color="#94a3b8", label="uses shaping + atlas"];
  NvimRpc -> NvimProcess [constraint=false, color="#94a3b8", label="transport over"];
  UiEventHandler -> Grid [constraint=false, color="#94a3b8", label="writes redraws"];
  UiEventHandler -> HighlightTable [constraint=false, color="#94a3b8", label="updates attrs"];
  NvimInput -> NvimRpc [constraint=false, color="#94a3b8", label="sends input"];
  UiRequestWorker -> NvimRpc [constraint=false, color="#94a3b8", label="async requests"];
  InputDispatcher -> HostManager [constraint=false, color="#94a3b8", label="mouse hit-test"];
  InputDispatcher -> UiPanel [constraint=false, color="#94a3b8", label="panel routing"];
  GuiActionHandler -> HostManager [constraint=false, color="#94a3b8", label="split panes"];
  GuiActionHandler -> UiPanel [constraint=false, color="#94a3b8", label="toggle diagnostics"];
  GuiActionHandler -> TextService [constraint=false, color="#94a3b8", label="font actions"];
  MegaCityHost -> UiPanel [constraint=false, color="#94a3b8", label="coexists with app ImGui"];
  MegaCityHost -> MetalRenderer [constraint=false, color="#94a3b8", label="registers 3D pass on macOS"];
  MegaCityHost -> VkRenderer [constraint=false, color="#94a3b8", label="registers 3D pass on Windows"];
}
