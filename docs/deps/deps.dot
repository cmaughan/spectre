    "node26" -> "node15"  // draxul-render-test -> draxul-renderer
    "node6" -> "node26"  // draxul-app -> draxul-render-test
    "node6" -> "node15"  // draxul-app -> draxul-renderer
    "node6" -> "node22"  // draxul-app -> draxul-runtime-support
    "node27" [ label = "draxul-ui", shape = octagon ];
    "node27" -> "node2" [ style = dotted ] // draxul-ui -> SDL3-static
    "node27" -> "node15" [ style = dotted ] // draxul-ui -> draxul-renderer
    "node27" -> "node8"  // draxul-ui -> draxul-types
    "node27" -> "node18"  // draxul-ui -> imgui
    "node6" -> "node27"  // draxul-app -> draxul-ui
    "node5" -> "node6" [ style = dotted ] // draxul -> draxul-app
    "node28" [ label = "draxul-megacity", shape = octagon ];
    "node29" [ label = "draxul-citydb", shape = octagon ];
    "node30" [ label = "draxul-treesitter", shape = octagon ];
    "node30" -> "node8"  // draxul-treesitter -> draxul-types
    "node31" [ label = "tree_sitter_core", shape = octagon ];
    "node30" -> "node31"  // draxul-treesitter -> tree_sitter_core
    "node32" [ label = "tree_sitter_cpp_grammar", shape = octagon ];
    "node30" -> "node32"  // draxul-treesitter -> tree_sitter_cpp_grammar
    "node29" -> "node30"  // draxul-citydb -> draxul-treesitter
    "node29" -> "node8"  // draxul-citydb -> draxul-types
    "node33" [ label = "sqlite3_lib", shape = octagon ];
    "node29" -> "node33"  // draxul-citydb -> sqlite3_lib
    "node28" -> "node29"  // draxul-megacity -> draxul-citydb
    "node28" -> "node7"  // draxul-megacity -> draxul-config
    "node28" -> "node10"  // draxul-megacity -> draxul-font
    "node34" [ label = "draxul-geometry", shape = octagon ];
