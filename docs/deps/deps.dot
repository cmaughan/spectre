digraph "draxul" {
node [
  fontsize = "12"
];
subgraph clusterLegend {
  label = "Legend";
  color = black;
  edge [ style = invis ];
  legendNode0 [ label = "Executable", shape = egg ];
  legendNode1 [ label = "Static Library", shape = octagon ];
  legendNode2 [ label = "Shared Library", shape = doubleoctagon ];
  legendNode3 [ label = "Module Library", shape = tripleoctagon ];
  legendNode4 [ label = "Interface Library", shape = pentagon ];
  legendNode5 [ label = "Object Library", shape = hexagon ];
  legendNode6 [ label = "Unknown Library", shape = septagon ];
  legendNode7 [ label = "Custom Target", shape = box ];
  legendNode0 -> legendNode1 [ style = solid ];
  legendNode0 -> legendNode2 [ style = solid ];
  legendNode0 -> legendNode3;
  legendNode1 -> legendNode4 [ label = "Interface", style = dashed ];
  legendNode2 -> legendNode5 [ label = "Private", style = dotted ];
  legendNode3 -> legendNode6 [ style = solid ];
  legendNode0 -> legendNode7;
}
    "node0" [ label = "Catch2\n(Catch2::Catch2)", shape = octagon ];
    "node1" [ label = "Catch2WithMain\n(Catch2::Catch2WithMain)", shape = octagon ];
    "node1" -> "node0"  // Catch2WithMain -> Catch2
    "node2" [ label = "SDL3-static\n(SDL3::SDL3)\n(SDL3::SDL3-static)", shape = octagon ];
    "node3" [ label = "SDL_uclibc", shape = octagon ];
    "node2" -> "node3"  // SDL3-static -> SDL_uclibc
    "node4" [ label = "SDL3_test\n(SDL3::SDL3_test)", shape = octagon ];
    "node5" [ label = "draxul", shape = egg ];
    "node6" [ label = "draxul-app", shape = octagon ];
    "node7" [ label = "draxul-config", shape = octagon ];
    "node7" -> "node2" [ style = dotted ] // draxul-config -> SDL3-static
    "node8" [ label = "draxul-types", shape = octagon ];
    "node9" [ label = "glm\n(glm::glm)", shape = octagon ];
    "node8" -> "node9"  // draxul-types -> glm
    "node7" -> "node8"  // draxul-config -> draxul-types
    "node6" -> "node7"  // draxul-app -> draxul-config
    "node10" [ label = "draxul-font", shape = octagon ];
    "node10" -> "node8"  // draxul-font -> draxul-types
    "node11" [ label = "freetype", shape = octagon ];
    "node10" -> "node11"  // draxul-font -> freetype
    "node12" [ label = "harfbuzz", shape = octagon ];
    "node12" -> "node11"  // harfbuzz -> freetype
    "node10" -> "node12"  // draxul-font -> harfbuzz
    "node6" -> "node10"  // draxul-app -> draxul-font
    "node13" [ label = "draxul-grid", shape = octagon ];
    "node13" -> "node8"  // draxul-grid -> draxul-types
    "node6" -> "node13"  // draxul-app -> draxul-grid
    "node14" [ label = "draxul-gui", shape = octagon ];
    "node14" -> "node10"  // draxul-gui -> draxul-font
    "node15" [ label = "draxul-renderer", shape = octagon ];
    "node15" -> "node2"  // draxul-renderer -> SDL3-static
    "node16" [ label = "draxul-renderer-core", shape = hexagon ];
    "node16" -> "node2"  // draxul-renderer-core -> SDL3-static
    "node16" -> "node8"  // draxul-renderer-core -> draxul-types
    "node17" [ label = "draxul-window", shape = octagon ];
    "node17" -> "node2"  // draxul-window -> SDL3-static
    "node17" -> "node8"  // draxul-window -> draxul-types
    "node16" -> "node17"  // draxul-renderer-core -> draxul-window
    "node18" [ label = "imgui", shape = octagon ];
    "node16" -> "node18"  // draxul-renderer-core -> imgui
    "node15" -> "node16"  // draxul-renderer -> draxul-renderer-core
    "node19" [ label = "draxul-renderer-vulkan", shape = hexagon ];
    "node19" -> "node2" [ style = dotted ] // draxul-renderer-vulkan -> SDL3-static
    "node19" -> "node8" [ style = dotted ] // draxul-renderer-vulkan -> draxul-types
    "node19" -> "node17" [ style = dotted ] // draxul-renderer-vulkan -> draxul-window
    "node19" -> "node18" [ style = dotted ] // draxul-renderer-vulkan -> imgui
    "node20" [ label = "vk-bootstrap\n(vk-bootstrap::vk-bootstrap)", shape = octagon ];
    "node19" -> "node20" [ style = dotted ] // draxul-renderer-vulkan -> vk-bootstrap
    "node15" -> "node19"  // draxul-renderer -> draxul-renderer-vulkan
    "node15" -> "node8"  // draxul-renderer -> draxul-types
    "node15" -> "node17"  // draxul-renderer -> draxul-window
    "node15" -> "node18"  // draxul-renderer -> imgui
    "node15" -> "node20" [ style = dotted ] // draxul-renderer -> vk-bootstrap
    "node14" -> "node15"  // draxul-gui -> draxul-renderer
    "node14" -> "node8"  // draxul-gui -> draxul-types
    "node6" -> "node14"  // draxul-app -> draxul-gui
    "node21" [ label = "draxul-host", shape = octagon ];
    "node21" -> "node10"  // draxul-host -> draxul-font
    "node21" -> "node13"  // draxul-host -> draxul-grid
    "node21" -> "node15"  // draxul-host -> draxul-renderer
    "node22" [ label = "draxul-runtime-support", shape = octagon ];
    "node22" -> "node7"  // draxul-runtime-support -> draxul-config
    "node22" -> "node10"  // draxul-runtime-support -> draxul-font
    "node22" -> "node13"  // draxul-runtime-support -> draxul-grid
    "node23" [ label = "draxul-nvim", shape = octagon ];
    "node23" -> "node2"  // draxul-nvim -> SDL3-static
    "node23" -> "node8"  // draxul-nvim -> draxul-types
    "node24" [ label = "mpack_lib", shape = octagon ];
    "node23" -> "node24"  // draxul-nvim -> mpack_lib
    "node22" -> "node23"  // draxul-runtime-support -> draxul-nvim
    "node22" -> "node15"  // draxul-runtime-support -> draxul-renderer
    "node22" -> "node17"  // draxul-runtime-support -> draxul-window
    "node21" -> "node22"  // draxul-host -> draxul-runtime-support
    "node21" -> "node8"  // draxul-host -> draxul-types
    "node21" -> "node17"  // draxul-host -> draxul-window
    "node6" -> "node21"  // draxul-app -> draxul-host
    "node25" [ label = "draxul-nanovg", shape = octagon ];
    "node25" -> "node15"  // draxul-nanovg -> draxul-renderer
    "node6" -> "node25"  // draxul-app -> draxul-nanovg
    "node6" -> "node23"  // draxul-app -> draxul-nvim
    "node26" [ label = "draxul-render-test", shape = octagon ];
    "node26" -> "node7"  // draxul-render-test -> draxul-config
    "node26" -> "node10"  // draxul-render-test -> draxul-font
    "node26" -> "node21"  // draxul-render-test -> draxul-host
