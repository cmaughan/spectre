digraph "draxul" {
node [
  fontsize = "12"
];
subgraph clusterLegend {
  label = "Legend";
  color = black;
  edge [ style = invis ];
  legendNode0 [ label = "Executable", shape = egg ];
  legendNode1 [ label = "Static Library", shape = octagon ];
  legendNode2 [ label = "Shared Library", shape = doubleoctagon ];
  legendNode3 [ label = "Module Library", shape = tripleoctagon ];
  legendNode4 [ label = "Interface Library", shape = pentagon ];
  legendNode5 [ label = "Object Library", shape = hexagon ];
  legendNode6 [ label = "Unknown Library", shape = septagon ];
  legendNode7 [ label = "Custom Target", shape = box ];
  legendNode0 -> legendNode1 [ style = solid ];
  legendNode0 -> legendNode2 [ style = solid ];
  legendNode0 -> legendNode3;
  legendNode1 -> legendNode4 [ label = "Interface", style = dashed ];
  legendNode2 -> legendNode5 [ label = "Private", style = dotted ];
  legendNode3 -> legendNode6 [ style = solid ];
  legendNode0 -> legendNode7;
}
    "node0" [ label = "Catch2\n(Catch2::Catch2)", shape = octagon ];
    "node1" [ label = "Catch2WithMain\n(Catch2::Catch2WithMain)", shape = octagon ];
    "node1" -> "node0"  // Catch2WithMain -> Catch2
    "node2" [ label = "SDL3-static\n(SDL3::SDL3)\n(SDL3::SDL3-static)", shape = octagon ];
    "node3" [ label = "SDL_uclibc", shape = octagon ];
    "node2" -> "node3"  // SDL3-static -> SDL_uclibc
    "node4" [ label = "SDL3_test\n(SDL3::SDL3_test)", shape = octagon ];
    "node5" [ label = "draxul", shape = egg ];
    "node6" [ label = "draxul-app-support", shape = octagon ];
    "node7" [ label = "draxul-font", shape = octagon ];
    "node8" [ label = "draxul-types", shape = octagon ];
    "node7" -> "node8"  // draxul-font -> draxul-types
    "node9" [ label = "freetype", shape = octagon ];
    "node10" [ label = "png_static", shape = octagon ];
    "node10" -> "node10"  // png_static -> png_static
    "node9" -> "node10" [ style = dotted ] // freetype -> png_static
    "node7" -> "node9"  // draxul-font -> freetype
    "node11" [ label = "harfbuzz", shape = octagon ];
    "node11" -> "node9"  // harfbuzz -> freetype
    "node7" -> "node11"  // draxul-font -> harfbuzz
    "node6" -> "node7"  // draxul-app-support -> draxul-font
    "node12" [ label = "draxul-grid", shape = octagon ];
    "node12" -> "node8"  // draxul-grid -> draxul-types
    "node6" -> "node12"  // draxul-app-support -> draxul-grid
    "node13" [ label = "draxul-nvim", shape = octagon ];
    "node13" -> "node2"  // draxul-nvim -> SDL3-static
    "node13" -> "node8"  // draxul-nvim -> draxul-types
    "node14" [ label = "mpack_lib", shape = octagon ];
    "node13" -> "node14"  // draxul-nvim -> mpack_lib
    "node6" -> "node13"  // draxul-app-support -> draxul-nvim
    "node15" [ label = "draxul-renderer", shape = octagon ];
    "node15" -> "node2"  // draxul-renderer -> SDL3-static
    "node15" -> "node8"  // draxul-renderer -> draxul-types
    "node16" [ label = "draxul-window", shape = octagon ];
    "node16" -> "node2"  // draxul-window -> SDL3-static
    "node16" -> "node8"  // draxul-window -> draxul-types
    "node15" -> "node16"  // draxul-renderer -> draxul-window
    "node17" [ label = "imgui", shape = octagon ];
    "node15" -> "node17"  // draxul-renderer -> imgui
    "node6" -> "node15"  // draxul-app-support -> draxul-renderer
    "node5" -> "node6" [ style = dotted ] // draxul -> draxul-app-support
    "node5" -> "node7" [ style = dotted ] // draxul -> draxul-font
    "node5" -> "node12" [ style = dotted ] // draxul -> draxul-grid
    "node18" [ label = "draxul-host", shape = octagon ];
    "node18" -> "node6"  // draxul-host -> draxul-app-support
    "node18" -> "node7"  // draxul-host -> draxul-font
    "node18" -> "node12"  // draxul-host -> draxul-grid
    "node18" -> "node15"  // draxul-host -> draxul-renderer
    "node18" -> "node8"  // draxul-host -> draxul-types
    "node18" -> "node16"  // draxul-host -> draxul-window
    "node5" -> "node18" [ style = dotted ] // draxul -> draxul-host
    "node19" [ label = "draxul-megacity", shape = octagon ];
    "node19" -> "node18"  // draxul-megacity -> draxul-host
    "node19" -> "node15"  // draxul-megacity -> draxul-renderer
    "node19" -> "node8"  // draxul-megacity -> draxul-types
    "node5" -> "node19" [ style = dotted ] // draxul -> draxul-megacity
    "node5" -> "node13" [ style = dotted ] // draxul -> draxul-nvim
    "node5" -> "node15" [ style = dotted ] // draxul -> draxul-renderer
    "node20" [ label = "draxul-ui", shape = octagon ];
    "node20" -> "node2" [ style = dotted ] // draxul-ui -> SDL3-static
    "node20" -> "node8"  // draxul-ui -> draxul-types
    "node20" -> "node17"  // draxul-ui -> imgui
    "node5" -> "node20" [ style = dotted ] // draxul -> draxul-ui
    "node21" [ label = "draxul-rpc-fake", shape = egg ];
    "node21" -> "node13" [ style = dotted ] // draxul-rpc-fake -> draxul-nvim
    "node22" [ label = "draxul-tests", shape = egg ];
    "node22" -> "node0" [ style = dotted ] // draxul-tests -> Catch2
    "node22" -> "node6" [ style = dotted ] // draxul-tests -> draxul-app-support
    "node22" -> "node7" [ style = dotted ] // draxul-tests -> draxul-font
    "node22" -> "node12" [ style = dotted ] // draxul-tests -> draxul-grid
    "node22" -> "node18" [ style = dotted ] // draxul-tests -> draxul-host
    "node22" -> "node13" [ style = dotted ] // draxul-tests -> draxul-nvim
    "node22" -> "node15" [ style = dotted ] // draxul-tests -> draxul-renderer
    "node22" -> "node20" [ style = dotted ] // draxul-tests -> draxul-ui
    "node23" [ label = "png_framework", shape = doubleoctagon ];
}
