# .clang-uml
# Configuration for clang-uml (https://clang-uml.github.io/)
# Generates a class diagram from C++ source using compile_commands.json.
#
# Usage:
#   clang-uml                              # generate all diagrams
#   python scripts/gen_uml.py              # generate + render to PNG/SVG
#   python scripts/gen_uml.py --diagram draxul_classes
#
# Diagrams are written to docs/uml/ as PlantUML (.puml) files.
# Render them with PlantUML or via scripts/gen_uml.py (which calls plantuml).

compilation_database_dir: ./build-tools
output_directory: ./docs/uml

# Suppress warnings from third-party headers that clang-uml treats as fatal.
# _CRT_SECURE_NO_WARNINGS: quiets MSVC fopen/getenv deprecations in log.cpp.
# -Wno-nullability-completeness: quiets _Nonnull/_Nullable warnings from VMA headers.
add_compile_flags:
  - -D_CRT_SECURE_NO_WARNINGS
  - -Wno-nullability-completeness
  # macOS: clang-uml's bundled libclang does not inherit the system compiler's
  # implicit header search paths.  Supply them explicitly so it can find both
  # the SDK headers (<functional>, <string>, …) and the compiler built-ins
  # (stdarg.h, __builtin_va_list, …).
  - -isysroot
  - /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk
  - -resource-dir
  - /opt/homebrew/Cellar/llvm@21/21.1.8/lib/clang/21

diagrams:

  # ── Class diagram ────────────────────────────────────────────────────────
  # Shows all classes, interfaces, and structs in the draxul namespace with
  # their inheritance and composition relationships.
  draxul_classes:
    type: class
    title: "Draxul — Class Diagram"
    using_namespace: draxul
    glob:
      - libs/draxul-types/src/*.cpp
      - libs/draxul-window/src/*.cpp
      - libs/draxul-renderer/src/*.cpp
      - libs/draxul-renderer/src/vulkan/*.cpp
      - libs/draxul-font/src/font_manager.cpp
      - libs/draxul-font/src/glyph_cache.cpp
      # text_service.cpp excluded: clang-uml 0.6.2 on Windows hits STATUS_STACK_OVERFLOW,
      # but TextService still appears in the diagram through included headers.
      # grid.cpp excluded: triggers a clang-uml 0.6.2 crash (STATUS_ILLEGAL_INSTRUCTION)
      - libs/draxul-nvim/src/nvim_process.cpp
      # rpc.cpp excluded: triggers SIGBUS in clang-uml 0.6.2
      # input.cpp excluded: triggers SIGBUS in clang-uml 0.6.2
      # mpack_codec.cpp excluded: triggers SIGBUS in clang-uml 0.6.2
      # ui_events.cpp excluded: triggers a clang-uml 0.6.2 crash (STATUS_ILLEGAL_INSTRUCTION)
      - app/app.cpp
    include:
      namespaces:
        - draxul
    exclude:
      namespaces:
        - std
        - mpack
        - boost
        - freetype
        - harfbuzz
      elements:
        - draxul::MpackValue::ArrayStorage
        - draxul::MpackValue::MapStorage
        - draxul::MpackValue::Storage
    generate_method_arguments: none
    generate_packages: false

  # Package diagram omitted: all code lives in one 'draxul' namespace so
  # there are no sub-namespaces to group. Library-level dependencies are
  # better visualised by the CMake graphviz graph (docs/deps/deps.svg).
